# Normalise line endings: store text as LF in the repo, check out native.
* text=auto

# Explicitly treat these as text.
*.py     text
*.js     text
*.css    text
*.html   text
*.md     text
*.txt    text
*.json   text
*.yml    text
*.yaml   text

# Binary assets — never normalise.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.webp   binary
*.pdf    binary
*.docx   binary
*.xlsx   binary
*.pptx   binary
*.ico    binary
