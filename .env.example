# ==========================================================
#  UDIP — Environment configuration template
#  Copy to ".env" and adjust. All values have safe defaults.
# ==========================================================

# --- General ---
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
# Default (zero-config): SQLite file in the project root.
# DATABASE_URL=sqlite:///./udip.db
# Production (PostgreSQL, per TZ section 5):
# DATABASE_URL=postgresql+psycopg2://udip:udip@localhost:5432/udip

# --- Cache (Redis) — leave empty to use the in-memory fallback ---
# REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO) — leave empty to use local-FS storage ---
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=udip-files
# MINIO_SECURE=false

# --- OCR ---
OCR_LANG=en
OCR_USE_GPU=false
OCR_MIN_CONFIDENCE=0.5

# --- AI / RAG ---
# AI_PROVIDER=stub        # stub | anthropic | openai
# AI_API_KEY=
# AI_MODEL=claude-sonnet-4-6
RAG_TOP_K=5

# --- Security ---
SECRET_KEY=change-me-in-production

# --- Upload limits ---
MAX_UPLOAD_MB=100
